# =============================================================================
# External services template — copy to `.env` and fill values for local / Dokploy tests
# =============================================================================
#
# Variable names map to pydantic-settings (case-insensitive). Prefer the names below.
#
# -----------------------------------------------------------------------------
# PostgreSQL (required) — choose ONE style:
# -----------------------------------------------------------------------------
# A) Single URL (Supabase, RDS, etc.):
DATABASE_URL=postgresql://USER:PASSWORD@db.example.com:5432/postgres?sslmode=require
#
# B) Components (no DATABASE_URL):
# POSTGRES_HOST=db.example.com
# POSTGRES_PORT=5432
# POSTGRES_USER=myuser
# POSTGRES_PASSWORD=secret
# POSTGRES_DB=mydb
#
# Optional schema for app tables (matches sql/repository_analysis_schema.sql):
POSTGRES_SCHEMA=repository_analysis
#
# Legacy single URL override:
# POSTGRES_URL=postgresql://...

# -----------------------------------------------------------------------------
# Neo4j (required) — Bolt endpoint from your host / Aura / cloud:
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j.example.com:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# -----------------------------------------------------------------------------
# Redis (required) — choose ONE style:
# -----------------------------------------------------------------------------
# A) Full URL (TLS: rediss://):
# REDIS_URL=redis://:PASSWORD@redis.example.com:6379/0
#
# B) Host + optional password:
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Startup / migrations
# -----------------------------------------------------------------------------
# Skip Alembic when a DBA already applied schema (recommended for restricted DB users).
SKIP_ALEMBIC_UPGRADE=true
#
# TCP wait before Uvicorn (Dockerfile entrypoint): unset *_WAIT_HOST = no wait (default; use with external DB/Neo4j/Redis).
# For a compose stack with service names postgres/neo4j/redis, set:
# POSTGRES_WAIT_HOST=postgres
# NEO4J_WAIT_HOST=neo4j
# REDIS_WAIT_HOST=redis
# Optional: SKIP_WAIT_FOR_DEPS=true forces skip even if *_WAIT_HOST are set.
#
# Skip TCP+DB checks at startup (debug only; app may fail on first request).
# SKIP_STARTUP_DEPENDENCY_CHECK=true

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_KEY=change-me
SECRET_KEY=change-me-long-random

# -----------------------------------------------------------------------------
# Optional — OpenAI-compatible API (key + base URL from env; no code changes needed)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# Base URL for chat/embeddings (OpenAI default below). Use your proxy/Azure/LiteLLM URL if needed.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.3
# OPENAI_MODEL_FALLBACKS=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# GITHUB_TOKEN=
