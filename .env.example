# Copy to `.env` in the repo root before `docker compose up`.
# Compose reads this file for `${VAR}` substitution. The backend service uses `env_file: .env`.
#
# Neo4j uses only explicit `environment:` in compose so unrelated keys are not passed into Neo4j.

# --- PostgreSQL (hosted: Supabase, self-hosted, etc.) ---
# DDL: an admin applies sql/repository_analysis_schema.sql, then sql/admin_grant_app_role.sql.
# The DATABASE_URL user should only have DML (SELECT/INSERT/UPDATE/DELETE), not CREATE/ALTER/DROP.
# DATABASE_URL=postgresql://app_user:...@host:5432/postgres?sslmode=require
DATABASE_URL=
# Must match the schema where admin created tables (see sql/repository_analysis_schema.sql).
# Leave empty to use the database default schema (usually public).
POSTGRES_SCHEMA=repository_analysis
# Keep true when the DB user must not run Alembic / DDL (recommended with admin_grant_app_role.sql).
SKIP_ALEMBIC_UPGRADE=true

# Legacy fallback if DATABASE_URL is unset (local dev only):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=codebase_analysis
# POSTGRES_URL=

# --- Neo4j (compose sets NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}; backend uses NEO4J_PASSWORD) ---
NEO4J_PASSWORD=

# --- Backend ---
API_KEY=
SECRET_KEY=

# The frontend is a separate repository. Configure its env there to match this API.

# OPENAI_API_KEY=
# GITHUB_TOKEN=
